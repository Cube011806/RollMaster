@model ICollection<Game>

@* @{
    ViewData["Title"] = "Index";
} *@

<h1>Lista Gier</h1>

@* <p>
    <a asp-page="Create">Create New</a>
</p> *@
<table class="table">
    <thead>
        <tr>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count != 0)
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.Id
                    </td>
                    <td>
                        @item.Name
                    </td>
                    <td>
                        @item.Description
                    </td>
                    <td>
                        @item.Characters
                    </td>
                    <td>
                        <a asp-action="AddPlayers" asp-route-id="@item.Id">Dodaj postaci</a> |
@*                         <a asp-action="Details" asp-route-id="@item.Id">Details</a> | *@
                        <a asp-action="DeleteGame" asp-route-id="@item.Id">Usuń</a>
                        @* @if (User.HasClaim("AccessLevel", "1")) 
                        {*@
                        | <a asp-action="GMDashboard" asp-route-id="@item.Id">GM Dashboard</a>
                        @*}*@
                    </td>
                </tr>
            }
            <a asp-action="CreateGame">Utwórz</a>
        }
        else
        {
            <p>Brak trwajacych gier</p>
            <a asp-action="CreateGame">Utwórz</a>
        }
    </tbody>
</table>
