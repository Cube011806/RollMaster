@model RollMaster.Models.Game

@{
    ViewData["Title"] = "Game Dashboard";
}

<h1>Game Dashboard – @Model.Name</h1>

<form asp-action="SaveGame" method="post">
    <input type="hidden" asp-for="Id" />

    @for (int c = 0; c < Model.Characters.Count; c++)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h3>@Model.Characters[c].Imie</h3>
            </div>

            <div class="card-body">
                <input type="hidden" asp-for="Characters[c].Id" />

                <div class="form-group">
                    <label asp-for="Characters[c].Wiek"></label>
                    <input asp-for="Characters[c].Wiek" class="form-control" type="number" />
                </div>

                <div class="form-group">
                    <label asp-for="Characters[c].PoziomZycia"></label>
                    <input asp-for="Characters[c].PoziomZycia" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="Characters[c].Skarb"></label>
                    <input asp-for="Characters[c].Skarb" class="form-control" type="number" />
                </div>

                <h5>Atrybuty</h5>

                <div class="form-group">
                    <label asp-for="Characters[c].WartoscSila"></label>
                    <input asp-for="Characters[c].WartoscSila" class="form-control" type="number" />
                </div>

                <div class="form-group">
                    <label asp-for="Characters[c].WartoscSerce"></label>
                    <input asp-for="Characters[c].WartoscSerce" class="form-control" type="number" />
                </div>

                <div class="form-group">
                    <label asp-for="Characters[c].WartoscRozum"></label>
                    <input asp-for="Characters[c].WartoscRozum" class="form-control" type="number" />
                </div>
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary">Zapisz wszystko</button>
</form>