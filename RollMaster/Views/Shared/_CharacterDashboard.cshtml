@model RollMaster.Models.Character

<form class="characterForm" data-character-id="@Model.Id">
    <input type="hidden" asp-for="Id" />
    <link rel="stylesheet" href="~/css/character.css" />

    <div class="tor-sheet">

        <div class="header">
            <div class="name">@Model.Imie</div>
        </div>

        <div class="top-info">
            <input type="hidden" asp-for="Imie" />
            <input type="hidden" asp-for="RodzimaKultura" />
            <input type="hidden" asp-for="RodzimaKorzysc" />
            <input type="hidden" asp-for="Powolanie" />
            <input type="hidden" asp-for="GameId" />
            <div>Rodzima Kultura: @Model.RodzimaKultura</div>
            <div>Rodzima Korzyść: @Model.RodzimaKorzysc</div>
            <div>Powołanie: @Model.Powolanie</div>
            <div>Wiek: <input asp-for="Wiek" /></div>
            <div>Patron: <input asp-for="Patron" /></div>
            <div>Ścieżka Cienia: <input asp-for="SciezkaCienia" /></div>
            <div>Skarb: <input asp-for="Skarb" /></div>
            <div>PoziomZycia: <input asp-for="PoziomZycia" /></div>
            <div>Wyróżniki: <input asp-for="Wyrozniki" /></div>
            <div>Przywary: <input asp-for="Przywary" /></div>
        </div>

        <div class="main">

            <!-- SIŁA -->
            <div class="column" style="grid-column: 1; grid-row: 1;">
                <h3>SIŁA</h3>
                <div class="attr-block">
                    <div class="field-row"><label>Wartość</label><input asp-for="WartoscSila" /></div>
                    <div class="field-row"><label>PT</label><span style="margin-right: 15px;">@(20 - Model.WartoscSila)</span></div>
                    <div class="field-row"><label>Wytrzymałość</label><input asp-for="Wytrzymalosc" /></div>
                </div>

                <div class="skills">
                    @for (int i = 0; i < 6; i++)
                    {
                        var skill = Model.Skills[i];
                        <div class="skill-row">
                            <input type="hidden" name="Skills[@i].Id" value="@skill.Id" />
                            <input type="checkbox" name="Skills[@i].IsEnhanced" value="true" @(skill.IsEnhanced ? "checked" : "") />
                            <span class="skill-name">@skill.Name</span>
                            <div class="skill-values">
                                @for (int val = 0; val <= 6; val++)
                                {
                                    <label class="radio-val">
                                        <input type="radio" name="Skills[@i].Value" value="@val" @(skill.Value == val ? "checked" : "") />
                                        <span>@val</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="horizontal-separator"></div>

                <div class="combat-skills">
                    <h5 style="text-align: center; margin: 10px 0; margin-bottom: 20px;">Biegłości bojowe</h5>
                    @for (int i = 18; i <= 21; i++)
                    {
                        var skill = Model.Skills[i];
                        <div class="skill-row">
                            <span class="skill-name" style="margin-left: 20px;">@skill.Name</span>
                            <div class="skill-values">
                                @for (int val = 0; val <= 6; val++)
                                {
                                    <label class="radio-val">
                                        <input type="hidden" name="Skills[@i].Id" value="@skill.Id" />
                                        <input type="radio" name="Skills[@i].Value" value="@val" @(skill.Value == val ? "checked" : "") />
                                        <span>@val</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- SERCE -->
            <div class="column" style="grid-column: 2; grid-row: 1;">
                <h3>SERCE</h3>
                <div class="attr-block">
                    <div class="field-row"><label>Wartość</label><input asp-for="WartoscSerce" /></div>
                    <div class="field-row"><label>PT</label><span style="margin-right: 15px;">@(20 - Model.WartoscSerce)</span></div>
                    <div class="field-row"><label>Nadzieja</label><input asp-for="Nadzieja" /></div>
                </div>

                <div class="skills">
                    @for (int i = 6; i < 12; i++)
                    {
                        var skill = Model.Skills[i];
                        <div class="skill-row">
                            <input type="hidden" name="Skills[@i].Id" value="@skill.Id" />
                            <input type="checkbox" name="Skills[@i].IsEnhanced" value="true" @(skill.IsEnhanced ? "checked" : "") />
                            <span class="skill-name">@skill.Name</span>
                            <div class="skill-values">
                                @for (int val = 0; val <= 6; val++)
                                {
                                    <label>
                                        <input type="radio" name="Skills[@i].Value" value="@val" @(skill.Value == val ? "checked" : "") />
                                        @val
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="horizontal-separator"></div>
                <div class="field-row">
                    <label for="Mestwo">Męstwo</label>
                    <input asp-for="Mestwo" />
                </div>
                <h5 style="text-align: center; margin: 10px 0;">Nagrody</h5>
                <textarea class="rew" asp-for="Nagrody" style="width: 100%; height: 150px;"></textarea>
            </div>

            <!-- ROZUM -->
            <div class="column" style="grid-column: 3; grid-row: 1; border-right: none;">
                <h3>ROZUM</h3>
                <div class="attr-block">
                    <div class="field-row"><label>Wartość</label><input asp-for="WartoscRozum" /></div>
                    <div class="field-row"><label>PT</label><span style="margin-right: 15px;">@(20 - Model.WartoscRozum)</span></div>
                    <div class="field-row"><label>Obrona</label><input asp-for="Obrona" /></div>
                </div>

                <div class="skills">
                    @for (int i = 12; i < 18; i++)
                    {
                        var skill = Model.Skills[i];
                        <div class="skill-row">
                            <input type="hidden" name="Skills[@i].Id" value="@skill.Id" />
                            <input type="checkbox" name="Skills[@i].IsEnhanced" value="true" @(skill.IsEnhanced ? "checked" : "") />
                            <span class="skill-name">@skill.Name</span>
                            <div class="skill-values">
                                @for (int val = 0; val <= 6; val++)
                                {
                                    <label class="radio-val">
                                        <input type="radio" name="Skills[@i].Value" value="@val" @(skill.Value == val ? "checked" : "") />
                                        <span>@val</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="horizontal-separator"></div>
                <div class="field-row">
                    <label for="Madrosc">Mądrość</label>
                    <input asp-for="Madrosc" />
                </div>
                <h5 style="text-align: center; margin: 10px 0;">Przymioty</h5>
                <textarea class="rew" asp-for="Przymioty" style="width: 100%; height: 150px;"></textarea>
            </div>

            <!-- PANEL BOCZNY -->
            <div class="side" style="grid-column: 4; grid-row: 1 / span 2; border-left: 2px solid #333; padding-left: 15px;">
                <div class="box">
                    <h4>Punkty</h4>
                    <div class="field-row"><label>Punkty Przygody</label><input asp-for="PunktyPrzygody" /></div>
                    <div class="field-row"><label>Punkty Umiejętności</label><input asp-for="PunktyUmiejetnosci" /></div>
                    <div class="field-row"><label>Punkty Zażyłości</label><input asp-for="PunktyZazylosci" /></div>
                </div>

                <div class="box">
                    <div class="field-row"><h5>Obecna Wytrzymałość</h5><input asp-for="ObecnaWytrzymalosc" /></div>
                    <div class="field-row"><label>Obciążenie</label><input asp-for="Obciazenie" /></div>
                    <div class="field-row"><label>Znużenie</label><input asp-for="Znuzenie" /></div>
                </div>

                <div class="box">
                    <div class="field-row"><h5>Obecna Nadzieja</h5><input asp-for="ObecnaNadzieja" /></div>
                    <div class="field-row"><label>Cień</label><input asp-for="Cien" /></div>
                    <div class="field-row"><label>Piętno Cienia</label><input asp-for="PietnoCienia" /></div>
                </div>

                <div class="box">
                    <h4>Ograniczenia</h4>
                    <div class="field-row"><label><input type="checkbox" asp-for="Wyczerpanie" /> Wyczerpanie</label></div>
                    <div class="field-row"><label><input type="checkbox" asp-for="Przygnebienie" /> Przygnębienie</label></div>
                    <div class="field-row"><label><input type="checkbox" asp-for="Rana" /> Rana</label></div>
                    <div class="field-row"><label>Stopień rany: </label><input type="text" asp-for="StopienRany" style="width: 150px;" /></div>
                </div>

                <div class="box">
                    <h4>Ekwipunek</h4>
                    <textarea class="eq" asp-for="Ekwipunek" style="width: 100%; height: 180px;"></textarea>
                </div>

                <div class="box">
                    <h4>Notatki</h4>
                    <textarea class="eq" asp-for="Notatki" style="width: 100%; height: 80px;"></textarea>
                </div>
            </div>

            <!-- RYNSZTUNEK I OCHRONA -->
            <div class="equipment-armor-grid" style="grid-column: 1 / span 3; grid-row: 2; border-top: 2px solid #333; padding-top: 15px; display: grid; grid-template-columns: 2fr 1fr; gap: 20px;">
                <div>
                    <h4 style="text-align: left;">RYNSZTUNEK</h4>
                    <div class="box">
                        <div class="weapon-row" style="font-weight: bold; border-bottom: 1px solid #aaa;">
                            <span>Broń</span><span>Obr.</span><span>Prz.</span><span>Obc.</span><span>Uwagi</span>
                        </div>
                        @for (int i = 0; i < 4; i++)
                        {
                            <div class="weapon-row">
                                <input type="hidden" name="weapons[@i].Id" value="@(i<Model.Weapons.Count? Model.Weapons[i].Id : 0)" />
                                <input name="weapons[@i].Name" value="@(i<Model.Weapons.Count? Model.Weapons[i].Name : "")" />
                                <input name="weapons[@i].Damage" value="@(i<Model.Weapons.Count? Model.Weapons[i].Damage : 0)" />
                                <input name="weapons[@i].Injury" value="@(i<Model.Weapons.Count? Model.Weapons[i].Injury : 0)" />
                                <input name="weapons[@i].Load" value="@(i<Model.Weapons.Count? Model.Weapons[i].Load : 0)" />
                                <input name="weapons[@i].Notes" value="@(i<Model.Weapons.Count? Model.Weapons[i].Notes : "")" />
                            </div>
                        }
                    </div>
                </div>

                <div>
                    <h4 style="text-align: center;">OCHRONA</h4>
                    <div class="box">
                        <div class="armor-row" style="font-weight: bold; border-bottom: 1px solid #aaa; display: grid; grid-template-columns: 2fr 1fr 1fr;">
                            <span>Zbroja</span><span>Panc.</span><span>Obc.</span>
                        </div>
                        <div class="armor-row" style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 5px; margin-bottom: 5px;">
                            <input type="hidden" asp-for="Zbroja.Id" />
                            <input asp-for="Zbroja.Nazwa" placeholder="Zbroja" />
                            <input asp-for="Zbroja.Pancerz" />
                            <input asp-for="Zbroja.Obciazenie" />
                        </div>

                        <div class="armor-row" style="font-weight: bold; border-bottom: 1px solid #aaa; display: grid; grid-template-columns: 2fr 1fr 1fr;">
                            <span>Hełm</span><span></span><span></span>
                        </div>
                        <div class="armor-row" style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 5px; margin-bottom: 5px;">
                            <input type="hidden" asp-for="Helm.Id" />
                            <input asp-for="Helm.Nazwa" placeholder="Hełm" />
                            <input asp-for="Helm.Pancerz" />
                            <input asp-for="Helm.Obciazenie" />
                        </div>

                        <div class="armor-row" style="font-weight: bold; border-bottom: 1px solid #aaa; display: grid; grid-template-columns: 2fr 1fr 1fr;">
                            <span>Tarcza</span><span>Obr.</span><span>Obc.</span>
                        </div>
                        <div class="armor-row" style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 5px; margin-bottom: 5px;">
                            <input type="hidden" asp-for="Tarcza.Id" />
                            <input asp-for="Tarcza.Nazwa" placeholder="Tarcza" />
                            <input asp-for="Tarcza.Obrona" />
                            <input asp-for="Tarcza.Obciazenie" />
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</form>

<script>
    // Obsługa auto-save AJAX
    (function() {
        const form = document.querySelector(".characterForm[data-character-id='@Model.Id']");
        if (!form) return;

        let timeout = null;

        form.addEventListener("change", function () {
            clearTimeout(timeout);

            timeout = setTimeout(function () {
                const formData = new FormData(form);
                fetch('/Character/SaveCharacter', {
                    method: 'POST',
                    body: formData
                });
            }, 500);
        });
    })();
</script>