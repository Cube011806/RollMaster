@model RollMaster.Models.Character

<link rel="stylesheet" href="~/css/character.css" />

<div class="tor-sheet">

    <!-- HEADER -->
    <div class="header">
        <div class="name">@Model.Imie</div>
    </div>

    <!-- TOP INFO -->
    <div class="top-info">
        <div>Rodzima kultura: @Model.RodzimaKultura</div>
        <div>Powołanie: @Model.Powolanie</div>
        <div>Wiek: <input asp-for="Wiek" /></div>
        <div>Patron: <input asp-for="Patron" /></div>
        <div>Skarb: <input asp-for="Skarb" /></div>
    </div>

    <!-- MAIN GRID -->
    <div class="main">

        <!-- SIŁA -->
        <div class="column">
            <h3>SIŁA</h3>
            <div class="attr-block">
                <label>Wartość</label>
                <input asp-for="WartoscSila" />
                <label>PT</label>
                <input asp-for="PTSila" />
                <label>Wytrzymałość</label>
                <input asp-for="Wytrzymalosc" />
            </div>

            <div class="skills">
                @for (int i = 0; i < 6; i++)
                {
                    var skill = Model.skills[i];
                    <div class="skill-row">
                        <label class="enhance-checkbox">
                            <input type="checkbox" name="skills[@i].IsEnhanced" value="true" @(skill.IsEnhanced ? "checked" : "") />
                        </label>

                        <span class="skill-name">@skill.Name</span>

                        <input type="hidden" name="skills[@i].Value" value="0" />

                        <div class="skill-values">
                            @for (int val = 1; val <= 6; val++)
                            {
                                <label>
                                    <input type="radio" name="skills[@i].Value" value="@val" @(skill.Value == val ? "checked" : "") />
                                    @val
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="horizontal-separator"></div>
            <div class="combat-skills">
                <h4>Biegłości bojowe</h4>
                @for (int i = 18; i <= 21; i++)
                {
                    var skill = Model.skills[i];
                    <div class="skill-row">
                        <!-- Nazwa biegłości -->
                        <span class="skill-name">@skill.Name</span>

                        <!-- Ukryty input dla wartości 0 -->
                        <input type="hidden" name="skills[@i].Value" value="0" />

                        <!-- Radio 1-6 -->
                        <div class="skill-values">
                            @for (int val = 1; val <= 6; val++)
                            {
                                <label>
                                    <input type="radio" name="skills[@i].Value" value="@val" @(skill.Value == val ? "checked" : "") />
                                    @val
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- SERCE -->
        <div class="column">
            <h3>SERCE</h3>
            <div class="attr-block">
                <label>Wartość</label>
                <input asp-for="WartoscSerce" />
                <label>PT</label>
                <input asp-for="PTSerce" />
                <label>Nadzieja</label>
                <input asp-for="Nadzieja" />
            </div>

            <div class="skills">
                @for (int i = 6; i < 12; i++)
                {
                    var skill = Model.skills[i];
                    <div class="skill-row">
                        <label class="enhance-checkbox">
                            <input type="checkbox" name="skills[@i].IsEnhanced" value="true" @(skill.IsEnhanced ? "checked" : "") />
                        </label>

                        <span class="skill-name">@skill.Name</span>

                        <input type="hidden" name="skills[@i].Value" value="0" />

                        <div class="skill-values">
                            @for (int val = 1; val <= 6; val++)
                            {
                                <label>
                                    <input type="radio" name="skills[@i].Value" value="@val" @(skill.Value == val ? "checked" : "") />
                                    @val
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>        
            <div class="horizontal-separator"></div>
        </div>
        <!-- ROZUM -->
        <div class="column">
            <h3>ROZUM</h3>
            <div class="attr-block">
                <label>Wartość</label>
                <input asp-for="WartoscRozum" />
                <label>PT</label>
                <input asp-for="PTRozum" />
                <label>Obrona</label>
                <input asp-for="Obrona" />
            </div>

            <div class="skills">
                @for (int i = 12; i < 18; i++)
                {
                    var skill = Model.skills[i];
                    <div class="skill-row">
                        <label class="enhance-checkbox">
                            <input type="checkbox" name="skills[@i].IsEnhanced" value="true" @(skill.IsEnhanced ? "checked" : "") />
                        </label>

                        <span class="skill-name">@skill.Name</span>

                        <input type="hidden" name="skills[@i].Value" value="0" />

                        <div class="skill-values">
                            @for (int val = 1; val <= 6; val++)
                            {
                                <label>
                                    <input type="radio" name="skills[@i].Value" value="@val" @(skill.Value == val ? "checked" : "") />
                                    @val
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="horizontal-separator"></div>
        </div>
        <!-- PRAWA KOLUMNA -->
        <div class="side">

            <div class="box">
                <h4>Punkty</h4>

                <label>Punkty Przygody</label>
                <input asp-for="PunktyPrzygody" />

                <label>Punkty Umiejętności</label>
                <input asp-for="PunktyUmiejetnosci" />

                <label>Poziom Zażyłości</label>
                <input asp-for="PunktyZazylosci" />
            </div>

            <div class="box">
                <h4>Stan</h4>

                <label>Obecna Wytrzymałość</label>
                <input asp-for="ObecnaWytrzymalosc" />

                <label>Obecna Nadzieja</label>
                <input asp-for="ObecnaNadzieja" />

                <label>Cień</label>
                <input asp-for="Cien" />

                <label>Piętno Cienia</label>
                <input asp-for="PietnoCienia" />
            </div>

            <div class="box">
                <h4>Stan</h4>
                <input asp-for="ObecnaWytrzymalosc" placeholder="Wytrzymałość" />
                <input asp-for="ObecnaNadzieja" placeholder="Nadzieja" />
                <input asp-for="Cien" placeholder="Cień" />
            </div>

            <div class="box">
                <h4>Ograniczenia</h4>
                <label><input asp-for="Wyczerpanie" /> Wyczerpanie</label>
                <label><input asp-for="Przygnebienie" /> Przygnębienie</label>
                <label><input asp-for="Rana" /> Rana</label>
            </div>

            <div class="box">
                <h4>Ekwipunek</h4>
                <textarea asp-for="Ekwipunek"></textarea>
            </div>

        </div>

    </div>

    <!-- RYNSZTUNEK -->
    <div class="equipment">
        <h3>Rynsztunek</h3>

        @for (int i = 0; i < 4; i++)
        {
            <div class="weapon-row">
                <input type="hidden" name="weapons[@i].Id" value="@(i<Model.weapons.Count? Model.weapons[i].Id : 0)" />
                <input type="hidden" name="weapons[@i].CharacterId" value="@Model.Id" />

                <input name="weapons[@i].Name" value="@(i<Model.weapons.Count? Model.weapons[i].Name : "")" placeholder="Nazwa" />
                <input name="weapons[@i].Damage" value="@(i<Model.weapons.Count? Model.weapons[i].Damage : 0)" />
                <input name="weapons[@i].Injury" value="@(i<Model.weapons.Count? Model.weapons[i].Injury : 0)" />
                <input name="weapons[@i].Load" value="@(i<Model.weapons.Count? Model.weapons[i].Load : 0)" />
                <input name="weapons[@i].Notes" value="@(i<Model.weapons.Count? Model.weapons[i].Notes : "")" />
            </div>
        }
    </div>
    <div class="armor-section">
        <h4>Zbroja</h4>
        <input asp-for="ZbrojaNazwa" placeholder="Nazwa" />
        <input asp-for="ZbrojaPancerz" placeholder="Pancerz" />
        <input asp-for="ZbrojaObciazenie" placeholder="Obciążenie" />

        <h4>Hełm</h4>
        <input asp-for="HelmNazwa" placeholder="Nazwa" />
        <input asp-for="HelmPancerz" placeholder="Pancerz" />
        <input asp-for="HelmObciazenie" placeholder="Obciążenie" />

        <h4>Tarcza</h4>
        <input asp-for="TarczaNazwa" placeholder="Nazwa" />
        <input asp-for="TarczaObrona" placeholder="Obrona" />
        <input asp-for="TarczaObciazenie" placeholder="Obciążenie" />
    </div>
</div>