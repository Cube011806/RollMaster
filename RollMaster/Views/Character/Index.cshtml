@model ICollection<Character>

@* @{
    ViewData["Title"] = "Index";
} *@

<h1>Lista Postaci</h1>

@* <p>
    <a asp-page="Create">Create New</a>
</p> *@
<table class="table">
    <thead>
        <tr>
        </tr>
    </thead>
    <tbody>
        @if(Model.Count != 0)
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.Imie
                    </td>
                    <td>
                        @item.RodzimaKultura
                    </td>
                    <td>
                        @item.Powolanie
                    </td>
                    <td>
                        @item.GameId
                    </td>
                    <td>
                        <a asp-action="EditCharacter" asp-route-id="@item.Id">Edit</a> |
                        <a asp-action="CharacterDashboard" asp-route-id="@item.Id">Karta postaci</a> |
                        <a asp-action="DeleteCharacter" asp-route-id="@item.Id">Delete</a> |
                        <a asp-action="DownloadJsonCharacter" asp-route-id="@item.Id">Pobierz postać</a>
                    </td>
                </tr>
            }
            <p>
                <a asp-action="CreateCharacter">Utwórz</a> | 
                <a asp-action="ImportCharacter">Import</a>
            </p>
        }
        else
        {
            <p>Brak postaci</p>
            <p>
            <a asp-action="CreateCharacter">Utwórz</a> | 
                <a asp-action="ImportCharacter">Import</a>
            </p>
        }
    </tbody>
</table>
