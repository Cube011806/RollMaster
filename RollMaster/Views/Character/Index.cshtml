@model ICollection<Character>

@{
    ViewData["Title"] = "Lista Postaci";
} 

<h1>Lista Postaci</h1>
<table class="table">
    <thead>
        <tr>
        </tr>
    </thead>
    <tbody>
        @if(Model.Count != 0)
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.Imie
                    </td>
                    <td>
                        @item.RodzimaKultura
                    </td>
                    <td>
                        @item.Powolanie
                    </td>
                    <td>
                        @if (item.GameId == null)
                        {
                            <span style="color: red">Brak przypisanej gry!</span>
                        }
                        else
                        {
                            @item.GameId
                        }
                    </td>
                    <td>
                        @* <a asp-action="EditCharacter" asp-route-id="@item.Id">Edit</a> | *@
                        <a class="btn btn-success" asp-action="CharacterDashboard" asp-route-id="@item.Id">Karta postaci</a> 
                        <a asp-action="DeleteCharacter" asp-route-id="@item.Id">Usuń</a> |
                        <a asp-action="DownloadJsonCharacter" asp-route-id="@item.Id">Pobierz postać</a>
                    </td>
                </tr>
            }
            <p>
                <a class="btn btn-danger" asp-action="CreateCharacter">Utwórz</a> @*|
                 <a asp-action="ImportCharacter" disabled>Import</a> *@
            </p>
        }
        else
        {
            <p>Brak postaci</p>
            <p>
                <a class="btn btn-danger" asp-action="CreateCharacter">Utwórz</a> @* |
                <a asp-action="ImportCharacter">Import</a> *@
            </p>
        }
    </tbody>
</table>
